-DATASET CSV empty

--

-CASE show_loaded_extensions
-SKIP_STATIC_LINK
-LOAD_DYNAMIC_EXTENSION fts
-STATEMENT CALL SHOW_LOADED_EXTENSIONS() RETURN *
---- 1
FTS|USER|${GORGONZOLA_ROOT_DIRECTORY}/extension/fts/build/libfts.gorgonzola_extension
-STATEMENT load extension "${GORGONZOLA_ROOT_DIRECTORY}/extension/duckdb/build/libduckdb.gorgonzola_extension"
---- ok
-STATEMENT CALL SHOW_LOADED_EXTENSIONS() RETURN *
---- 2
FTS|USER|${GORGONZOLA_ROOT_DIRECTORY}/extension/fts/build/libfts.gorgonzola_extension
DUCKDB|USER|${GORGONZOLA_ROOT_DIRECTORY}/extension/duckdb/build/libduckdb.gorgonzola_extension
-STATEMENT load extension "${GORGONZOLA_ROOT_DIRECTORY}/extension/httpfs/build/libhttpfs.gorgonzola_extension"
---- ok
-STATEMENT CALL SHOW_LOADED_EXTENSIONS() RETURN *
---- 3
FTS|USER|${GORGONZOLA_ROOT_DIRECTORY}/extension/fts/build/libfts.gorgonzola_extension
DUCKDB|USER|${GORGONZOLA_ROOT_DIRECTORY}/extension/duckdb/build/libduckdb.gorgonzola_extension
HTTPFS|USER|${GORGONZOLA_ROOT_DIRECTORY}/extension/httpfs/build/libhttpfs.gorgonzola_extension
